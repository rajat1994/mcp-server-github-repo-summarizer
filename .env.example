# Copy this to .env and edit the values.

# Ollama model used for codebase summary + improvement suggestions.
# Pull it first with: ollama pull <model>
# Good choices: llama3.2, llama3.1, qwen2.5-coder, mistral, codellama
OLLAMA_MODEL=llama3.2

# Ollama server host. Default is fine for a local `ollama serve`.
OLLAMA_HOST=http://localhost:11434

# Context window passed to the model. Bump higher for bigger repos if the
# model supports it (e.g. 32768). Lower if your machine runs out of memory.
OLLAMA_NUM_CTX=16384

# Optional: GitHub personal access token. Only needed to raise the unauthenticated
# rate limit (60 req/hr -> 5000 req/hr). Leave blank for public-repo use.
GITHUB_TOKEN=
